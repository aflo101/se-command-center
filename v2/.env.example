# Copy to .env.local (gitignored) and fill in real values for a deployment.
# All are optional — the app runs on generic demo defaults without them.

# --- Frontend (Vite, must be VITE_-prefixed) ---
VITE_OWNER_NAME="Jordan Mercer"
VITE_VENDOR_NAME="Aegis Data Security"
VITE_APP_NAME="SE Command"
# CRM deep-link base for the opportunity panel's Salesforce/CRM link:
VITE_SFDC_BASE_URL="https://crm.example/opportunity"

# --- Server ---
PORT=3001
# Owner whose opportunities the dashboard shows (must match data in pipeline.db):
SE_OWNER="Jordan Mercer"
SFDC_BASE_URL="https://crm.example/opportunity"
# Override the SQLite path if your DB lives elsewhere:
# SE_DB_PATH="/absolute/path/to/pipeline.db"

# --- Dormant connectors (see CONNECTORS.md) ---
# NOTION_TOKEN=""
